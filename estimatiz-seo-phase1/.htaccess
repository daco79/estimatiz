# =============================================================================
# .htaccess — Estimatiz (Phase SEO 1)
# =============================================================================

# Page d'accueil par défaut
DirectoryIndex index.php index.html

# ── Compression GZIP ─────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml font/woff2
</IfModule>

# ── Cache navigateur ─────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 hour"
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
  ExpiresByType image/webp "access plus 6 months"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/xml "access plus 1 day"
</IfModule>

# ── Headers de sécurité (Phase SEO 1) ────────────────────────────────────────
<IfModule mod_headers.c>
  # Empêche le sniffing du type MIME
  Header always set X-Content-Type-Options "nosniff"

  # Empêche l'embarquement dans des iframes (clickjacking)
  Header always set X-Frame-Options "SAMEORIGIN"

  # Politique de référent (envoie l'origine seulement, pas le path)
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Restreint les API navigateur sensibles (geolocation, camera, micro)
  Header always set Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=()"

  # HSTS — force HTTPS pendant 1 an (à activer SEULEMENT si HTTPS est stable)
  # Décommente la ligne suivante quand tu es sûr que tout passe en HTTPS
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # Cache long pour assets versionnés
  <FilesMatch "\.(css|js|jpg|jpeg|png|gif|svg|ico|woff|woff2)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

# ── Bloquer les fichiers privés ──────────────────────────────────────────────
<FilesMatch "^(config\.(local|o2switch)\.php|test_connexion\.php|deploy\.sh|restore\.py)$">
  Require all denied
</FilesMatch>

# Cache serveur jamais accessible
RedirectMatch 403 ^/\.cache(/|$)
RedirectMatch 403 ^/_Base(/|$)
RedirectMatch 403 ^/_Backup(/|$)

# ── Réécriture d'URL ─────────────────────────────────────────────────────────
RewriteEngine On

# Force HTTPS (à activer si SSL est stable sur o2switch)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Force le www (cohérence avec canonicals)
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !\. [NC]
RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 301 : anciennes URLs .html → sans extension
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 301 : URLs .php (pages publiques) → sans extension
# Exclut /api/, les configs et les fichiers système
RewriteCond %{THE_REQUEST} \s/+((?!api/)[^?\s]+?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Rewrite interne : URL propre → fichier .php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^.]+)$ $1.php [L]

# ── Erreurs personnalisées (optionnel — à créer plus tard) ───────────────────
# ErrorDocument 404 /404.php
# ErrorDocument 500 /500.php
