# =============================================================================
# .htaccess Estimatiz — Phase 1 + correctifs sécurité
# Modifications par rapport à la version précédente :
#   + Headers de sécurité (X-Content-Type-Options, X-Frame-Options, Referrer-Policy, Permissions-Policy)
#   + Force www. (canonicals utilisent www, on aligne le serveur)
#   + HSTS commenté (à activer SEULEMENT après confirmation HTTPS sur tous les sous-domaines)
#   + Cache statique étendu (favicons, fonts)
#   + Compression étendue aux fonts et JSON
# =============================================================================

# Page d'accueil par défaut
DirectoryIndex index.php index.html

# -----------------------------------------------------------------------------
# 1. Headers de sécurité (CRITIQUE — manquait avant)
# -----------------------------------------------------------------------------
<IfModule mod_headers.c>
  # Empêche le navigateur de "deviner" un type MIME différent (anti-XSS)
  Header always set X-Content-Type-Options "nosniff"

  # Empêche l'iframe sur d'autres domaines (anti-clickjacking)
  Header always set X-Frame-Options "SAMEORIGIN"

  # Limite les infos envoyées dans le Referer (vie privée + sécurité)
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Désactive les API navigateur sensibles (le site n'en a pas besoin)
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()"

  # HSTS — force HTTPS pendant 1 an
  # ⚠️ NE PAS DÉCOMMENTER avant d'avoir confirmé que TOUS les sous-domaines tournent en HTTPS
  # Une fois activé, le navigateur refusera tout accès HTTP pendant 1 an même si tu le veux
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# -----------------------------------------------------------------------------
# 2. Compression
# -----------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml application/rss+xml
  AddOutputFilterByType DEFLATE application/x-font-ttf application/x-font-otf font/woff font/woff2
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# -----------------------------------------------------------------------------
# 3. Cache navigateur des fichiers statiques
# -----------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"

  # CSS / JS — 1 mois
  ExpiresByType text/css                   "access plus 1 month"
  ExpiresByType application/javascript     "access plus 1 month"
  ExpiresByType text/javascript            "access plus 1 month"

  # Images — 6 mois (rarement modifiées)
  ExpiresByType image/jpeg                 "access plus 6 months"
  ExpiresByType image/png                  "access plus 6 months"
  ExpiresByType image/webp                 "access plus 6 months"
  ExpiresByType image/avif                 "access plus 6 months"
  ExpiresByType image/svg+xml              "access plus 6 months"
  ExpiresByType image/x-icon               "access plus 1 year"
  ExpiresByType image/vnd.microsoft.icon   "access plus 1 year"

  # Fonts — 1 an (versionnées)
  ExpiresByType font/woff                  "access plus 1 year"
  ExpiresByType font/woff2                 "access plus 1 year"
  ExpiresByType application/x-font-ttf     "access plus 1 year"
  ExpiresByType application/x-font-otf     "access plus 1 year"

  # HTML — pas de cache long (le site bouge)
  ExpiresByType text/html                  "access plus 0 seconds"

  # XML / sitemap — courte durée
  ExpiresByType application/xml            "access plus 1 hour"
  ExpiresByType text/xml                   "access plus 1 hour"
</IfModule>

# -----------------------------------------------------------------------------
# 4. Bloquer les fichiers privés et le cache serveur
# -----------------------------------------------------------------------------
<FilesMatch "^(config\.(local|o2switch)\.php|test_connexion\.php|deploy\.sh|backup\.py|restore\.py|generate_results\.py)$">
  Require all denied
</FilesMatch>

# Bloquer les fichiers cachés (.git, .env, etc.)
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# Bloquer le cache et les dossiers techniques
RedirectMatch 403 ^/\.cache(/|$)
RedirectMatch 403 ^/_Base(/|$)
RedirectMatch 403 ^/_Backup(/|$)
RedirectMatch 403 ^/lib(/|$)
RedirectMatch 403 ^/includes(/|$)

# -----------------------------------------------------------------------------
# 5. Réécriture URL
# -----------------------------------------------------------------------------
RewriteEngine On

# 5.1 — Force HTTPS + www. (CRITIQUE pour SEO)
# Tous les canonicals utilisent https://www.estimatiz.fr/ — on aligne ici
# Exception : localhost (génération Python locale)
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteCond %{HTTP_HOST} ^(?:www\.)?(.+)$ [NC]
RewriteRule ^ https://www.%1%{REQUEST_URI} [R=301,L,NE]

# 5.2 — 301 : anciennes URLs .html → sans extension
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 5.3 — 301 : URLs .php (pages publiques) → sans extension
# Exclut /api/, les configs et les fichiers système
RewriteCond %{THE_REQUEST} \s/+((?!api/)[^?\s]+?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 5.4 — Rewrite interne : URL propre → fichier .php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^.]+)$ $1.php [L]

# -----------------------------------------------------------------------------
# 6. Pages d'erreur (optionnel mais recommandé)
# -----------------------------------------------------------------------------
# ErrorDocument 404 /404.php
# ErrorDocument 500 /500.php
